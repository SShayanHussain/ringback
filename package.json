{
  "name": "ringback",
  "private": true,
  "version": "0.1.0",
  "description": "Ringback — inbound voice agent for home-services scheduling (text-first).",
  "workspaces": [
    "web",
    "packages/*"
  ],
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "scripts": {
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "lint": "npm run lint --workspace web",
    "playground": "python -m ringback_agent.playground",
    "test": "npm run test --workspace web"
  },
  "engines": {
    "node": ">=20"
  }
}
